# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real keys.
#   cp .env.example .env        (macOS / Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
#
# NEVER commit your real .env file. It is already in .gitignore.
# ----------------------------------------------------------------------------

# Choose which provider to use: "groq" or "gemini"
LLM_PROVIDER=groq

# --- Groq ---  Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---  Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Optional: point Kokoro/phonemizer at your espeak-ng library (Windows) ---
# PHONEMIZER_ESPEAK_LIBRARY=C:\Program Files\eSpeak NG\libespeak-ng.dll
